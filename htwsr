-- LocalBrainrotSpawnerInYourPlot.lua
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer

-- Config
local ANIMALS_FOLDER = ReplicatedStorage:FindFirstChild("Models") and ReplicatedStorage.Models:FindFirstChild("Animals")
if not ANIMALS_FOLDER then
    warn("ReplicatedStorage.Models.Animals not found. Aborting.")
    return
end

-- Function to find your personal plot
local function getMyPlot()
    local plotsFolder = workspace:FindFirstChild("Plots") or workspace:FindFirstChild("plots")
    if not plotsFolder then return nil end
    for _, plot in ipairs(plotsFolder:GetChildren()) do
        local label = plot:FindFirstChild("PlotSign")
            and plot.PlotSign:FindFirstChild("SurfaceGui")
            and plot.PlotSign.SurfaceGui:FindFirstChild("Frame")
            and plot.PlotSign.SurfaceGui.Frame:FindFirstChild("TextLabel")
        if label and label.Text:find(player.DisplayName) then
            return plot
        end
    end
    return nil
end

-- Create local folder inside plot for client-only clones
local function getLocalFolder(plot)
    local folder = plot:FindFirstChild("LocalBrainrots")
    if not folder then
        folder = Instance.new("Folder")
        folder.Name = "LocalBrainrots"
        folder.Parent = plot
    end
    return folder
end

-- Safe clone helper
local function safeClone(template)
    local ok, clone = pcall(function() return template:Clone() end)
    if not ok or not clone then return nil end
    if not clone.PrimaryPart then
        local prim = clone:FindFirstChildWhichIsA("BasePart", true)
        if prim then clone.PrimaryPart = prim end
    end
    for _, d in ipairs(clone:GetDescendants()) do
        if d:IsA("BasePart") then
            d.Anchored = true
            d.CanCollide = false
        elseif d:IsA("Script") or d:IsA("LocalScript") or d:IsA("ModuleScript") then
            pcall(function() d:Destroy() end)
        end
    end
    return clone
end

-- Place clone at position in plot
local function placeCloneAt(folder, clone, pos)
    if clone.PrimaryPart then
        clone:SetPrimaryPartCFrame(CFrame.new(pos))
    else
        local root = clone:FindFirstChildWhichIsA("BasePart", true)
        if root then root.Position = pos end
    end
    clone.Parent = folder
end

-- Spawn 67 brainrots in your plot in a neat grid
local function spawnBrainrotsInPlot()
    local plot = getMyPlot()
    if not plot then
        warn("Could not find your plot.")
        return
    end
    local folder = getLocalFolder(plot)
    
    -- Clear previous
    for _, obj in ipairs(folder:GetChildren()) do
        pcall(function() obj:Destroy() end)
    end
    
    local templates = ANIMALS_FOLDER:GetChildren()
    if #templates == 0 then
        warn("No templates found in Models.Animals")
        return
    end
    
    -- Use a reference part in plot (first BasePart found)
    local plotRoot = plot:FindFirstChildWhichIsA("BasePart", true)
    if not plotRoot then
        plotRoot = Instance.new("Part")
        plotRoot.Position = plot:GetModelCFrame().p or Vector3.new(0,5,0)
    end

    local centerPos = plotRoot.Position + Vector3.new(0,2,0) -- slight vertical offset
    local side = math.ceil(math.sqrt(67))
    local spacing = 3
    local idx = 0

    for y = 1, side do
        for x = 1, side do
            if idx >= 67 then break end
            local template = templates[(idx % #templates) + 1]
            local clone = safeClone(template)
            local pos = centerPos + Vector3.new((x-(side+1)/2)*spacing, 0, (y-(side+1)/2)*spacing)
            placeCloneAt(folder, clone, pos)
            idx = idx + 1
        end
        if idx >= 67 then break end
    end
end

-- Keybinds
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.B then
        spawnBrainrotsInPlot()
    elseif input.KeyCode == Enum.KeyCode.R then
        local plot = getMyPlot()
        if plot then
            local folder = plot:FindFirstChild("LocalBrainrots")
            if folder then
                for _, obj in ipairs(folder:GetChildren()) do
                    pcall(function() obj:Destroy() end)
                end
            end
        end
    end
end)

print("Client-side brainrot plot spawner loaded. Press B to spawn 67 brainrots in your plot. Press R to clear.")
