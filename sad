<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ZuriScripts</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0610;
      --surface: #130d1e;
      --surface2: #1a1028;
      --accent: #b44fff;
      --accent2: #d97cff;
      --pink: #ff4ecd;
      --soft: #e8b4ff;
      --text: #f0e6ff;
      --muted: #7a5a99;
      --border: #2a1545;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Share Tech Mono', monospace;
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(180,79,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(180,79,255,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse at 15% 20%, rgba(180,79,255,0.14) 0%, transparent 50%),
        radial-gradient(ellipse at 85% 75%, rgba(255,78,205,0.10) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      max-width: 800px;
      margin: 0 auto;
      padding: 50px 20px 100px;
    }

    /* HEADER */
    header {
      text-align: center;
      margin-bottom: 52px;
      animation: fadeDown 0.7s ease both;
      background: linear-gradient(135deg, rgba(26,16,40,0.95), rgba(40,16,60,0.8));
      border: 1px solid rgba(180,79,255,0.28);
      border-radius: 18px;
      padding: 36px 28px 28px;
      box-shadow: 0 0 60px rgba(180,79,255,0.12), inset 0 1px 0 rgba(255,255,255,0.04);
    }

    .logo {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: clamp(2rem, 6vw, 3.4rem);
      letter-spacing: 0.02em;
      background: linear-gradient(135deg, #d97cff 0%, #b44fff 45%, #ff4ecd 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 22px rgba(180,79,255,0.55));
      line-height: 1.1;
    }

    .tagline {
      margin-top: 7px;
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--soft);
      opacity: 0.8;
    }

    .yt-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin-top: 11px;
      padding: 6px 14px;
      background: rgba(255,78,205,0.1);
      border: 1px solid rgba(255,78,205,0.3);
      border-radius: 100px;
      font-size: 0.71rem;
      letter-spacing: 0.1em;
      color: #ff85df;
    }

    .yt-icon {
      width: 14px; height: 14px;
      fill: #ff4ecd;
      flex-shrink: 0;
    }

    /* DIVIDER */
    .divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), var(--pink), transparent);
      margin: 0 0 40px;
      opacity: 0.45;
    }

    /* SCRIPT CARD */
    .script-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      margin-bottom: 22px;
      overflow: hidden;
      box-shadow: 0 0 40px rgba(180,79,255,0.06), 0 8px 32px rgba(0,0,0,0.5);
      animation: fadeUp 0.55s ease both;
      transition: box-shadow 0.3s, border-color 0.3s;
    }
    .script-card:hover {
      border-color: rgba(180,79,255,0.4);
      box-shadow: 0 0 50px rgba(180,79,255,0.16), 0 8px 32px rgba(0,0,0,0.5);
    }
    .script-card:nth-child(1) { animation-delay: 0.05s; }
    .script-card:nth-child(2) { animation-delay: 0.15s; }
    .script-card:nth-child(3) { animation-delay: 0.25s; }

    .card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 13px 18px;
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
    }

    .script-name {
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: 0.74rem;
      letter-spacing: 0.1em;
      color: var(--accent2);
      text-transform: uppercase;
    }

    .badge {
      font-size: 0.64rem;
      padding: 3px 12px;
      border-radius: 100px;
      background: rgba(180,79,255,0.15);
      border: 1px solid rgba(180,79,255,0.4);
      color: var(--accent2);
      letter-spacing: 0.08em;
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
    }
    .badge.vip {
      background: rgba(255,78,205,0.12);
      border-color: rgba(255,78,205,0.4);
      color: #ff85df;
    }

    .script-body {
      padding: 20px 20px;
      font-size: 0.84rem;
      line-height: 1.75;
      color: #c89ae8;
      white-space: pre-wrap;
      word-break: break-all;
      min-height: 72px;
      user-select: all;
      border-left: 3px solid rgba(180,79,255,0.35);
    }

    .card-bottom {
      padding: 12px 18px;
      border-top: 1px solid var(--border);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .script-info {
      font-size: 0.67rem;
      color: var(--muted);
      letter-spacing: 0.05em;
    }

    .copy-btn {
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: 0.69rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 10px 22px;
      border-radius: 8px;
      border: 1px solid var(--accent);
      background: linear-gradient(135deg, rgba(180,79,255,0.18), rgba(180,79,255,0.06));
      color: var(--accent2);
      cursor: pointer;
      transition: all 0.2s;
    }
    .copy-btn:hover {
      background: linear-gradient(135deg, rgba(180,79,255,0.38), rgba(180,79,255,0.18));
      box-shadow: 0 0 22px rgba(180,79,255,0.45);
      color: #fff;
    }
    .copy-btn:active { transform: scale(0.96); }
    .copy-btn.copied {
      border-color: #d97cff;
      background: linear-gradient(135deg, rgba(180,79,255,0.45), rgba(255,78,205,0.25));
      color: #fff;
      box-shadow: 0 0 26px rgba(180,79,255,0.55);
    }

    /* TOAST */
    .toast {
      position: fixed;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%) translateY(16px);
      background: linear-gradient(135deg, #b44fff, #ff4ecd);
      color: #fff;
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      padding: 12px 30px;
      border-radius: 100px;
      opacity: 0;
      transition: opacity 0.22s, transform 0.22s;
      pointer-events: none;
      z-index: 999;
      box-shadow: 0 0 32px rgba(180,79,255,0.55);
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    footer {
      text-align: center;
      margin-top: 60px;
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.1em;
    }
    footer a { color: var(--accent); text-decoration: none; }
    footer a:hover { color: var(--accent2); }
  </style>
</head>
<body>

<div class="container">

  <header>
    <div class="logo">ZuriScripts</div>
    <div class="tagline">Trusted by 10,000+ Players Daily!</div>
    <div class="yt-badge">
      <svg class="yt-icon" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1C4.5 20.5 12 20.5 12 20.5s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.8 15.5V8.5l6.2 3.5-6.2 3.5z"/></svg>
      YT: Zuriscripts
    </div>
  </header>

  <div class="divider"></div>

  <div class="script-card">
    <div class="card-top">
      <span class="script-name">⚡ Zuri Hub Script</span>
      <span class="badge vip">PREMIUM</span>
    </div>
    <div class="script-body" id="script1">loadstring(game:HttpGet("https://raw.githubusercontent.com/ZuriHubV2/ZuriScripts/refs/heads/main/Mm2Hub"))()</div>
    <div class="card-bottom">
      <span class="script-info">// Paste into your executor</span>
      <button class="copy-btn" onclick="copyScript('script1', this)">⧉ Copy Script</button>
    </div>
  </div>

  <div class="script-card">
    <div class="card-top">
      <span class="script-name">⚡ Weapon Spawner Script</span>
      <span class="badge vip">PREMIUM</span>
    </div>
    <div class="script-body" id="script2">loadstring(game:HttpGet("https://raw.githubusercontent.com/ZuriHubV2/ZuriScripts/refs/heads/main/Mm2Spawner"))()</div>
    <div class="card-bottom">
      <span class="script-info">// Paste into your executor</span>
      <button class="copy-btn" onclick="copyScript('script2', this)">⧉ Copy Script</button>
    </div>
  </div>

  <div class="script-card">
    <div class="card-top">
      <span class="script-name">⚡ Trade Freeze Script</span>
      <span class="badge vip">PREMIUM</span>
    </div>
    <div class="script-body" id="script3">loadstring(game:HttpGet("https://raw.githubusercontent.com/ZuriHubV2/ZuriScripts/refs/heads/main/TradeFreeze.lua"))()</div>
    <div class="card-bottom">
      <span class="script-info">// Paste into your executor</span>
      <button class="copy-btn" onclick="copyScript('script3', this)">⧉ Copy Script</button>
    </div>
  </div>

  <footer>
    © 2026 ZuriScripts &nbsp;·&nbsp;
    <a href="https://youtube.com/@Zuriscripts" target="_blank">YouTube: Zuriscripts</a>
    &nbsp;·&nbsp; Use responsibly
  </footer>
</div>

<div class="toast" id="toast">✓ Script Copied!</div>

<script>
  function copyScript(id, btn) {
    const text = document.getElementById(id).innerText;
    navigator.clipboard.writeText(text).then(() => {
      const orig = btn.innerHTML;
      btn.innerHTML = '✓ Copied!';
      btn.classList.add('copied');
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2200);
      const t = document.getElementById('toast');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2200);
    });
  }
</script>

</body>
</html>
