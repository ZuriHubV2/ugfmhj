-- LocalBrainrotSpawner67.lua  (LocalScript -> StarterPlayerScripts)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- Config
local ANIMALS_FOLDER = ReplicatedStorage:WaitForChild("Models"):WaitForChild("Animals")
local PLOTS_PARENT = workspace:FindFirstChild("Plots") or workspace:FindFirstChild("plots") or workspace
local LOCAL_FOLDER_NAME = "LocalClientBrainrots"
local TOTAL_TO_SPAWN = 67
local DEFAULT_SCALE = 1
local SPACING = 3 -- space between brainrots

-- Create local folder
local localFolder = workspace:FindFirstChild(LOCAL_FOLDER_NAME)
if not localFolder then
    localFolder = Instance.new("Folder")
    localFolder.Name = LOCAL_FOLDER_NAME
    localFolder.Parent = workspace
end

local spawned = {}

local function cloneTemplate(template, position, scale)
    local ok, clone = pcall(function() return template:Clone() end)
    if not ok or not clone then return nil end

    clone.Parent = localFolder
    if not clone.PrimaryPart then
        local primary = clone:FindFirstChildWhichIsA("BasePart", true)
        if primary then clone.PrimaryPart = primary end
    end
    for _,p in ipairs(clone:GetDescendants()) do
        if p:IsA("BasePart") then
            p.Anchored = true
            p.CanCollide = false
        end
    end
    if scale and type(scale)=="number" then
        for _,p in ipairs(clone:GetDescendants()) do
            if p:IsA("BasePart") then
                p.Size = p.Size * scale
            end
        end
    end

    if clone.PrimaryPart then
        clone:SetPrimaryPartCFrame(CFrame.new(position) * CFrame.Angles(0, math.rad(math.random()*360), 0))
    else
        local root = clone:FindFirstChildWhichIsA("BasePart", true)
        if root then root.Position = position end
    end

    -- parent into workspace.Plots if exists
    if PLOTS_PARENT then
        clone.Parent = PLOTS_PARENT
    end

    clone.Name = (clone.Name or "Brainrot").."_local_"..tostring(math.floor(tick()*1000))
    spawned[clone] = true
    return clone
end

-- Spawn multiple brainrots in grid
local function spawnMultipleBrainrots(count)
    local templates = ANIMALS_FOLDER:GetChildren()
    if #templates == 0 then warn("No templates found in ReplicatedStorage.Models.Animals") return end
    local center = camera.CFrame.Position + camera.CFrame.LookVector*8
    local side = math.ceil(math.sqrt(count))
    local idx = 0
    for y = 1, side do
        for x = 1, side do
            if idx >= count then break end
            local template = templates[((idx)%#templates)+1]
            local offset = Vector3.new((x-(side+1)/2)*SPACING,0,(y-(side+1)/2)*SPACING)
            local pos = center + offset
            cloneTemplate(template, pos, DEFAULT_SCALE)
            idx = idx + 1
        end
        if idx >= count then break end
    end
end

-- Clear local spawns
local function clearBrainrots()
    for obj,_ in pairs(spawned) do
        if obj and obj.Parent then
            pcall(function() obj:Destroy() end)
        end
        spawned[obj] = nil
    end
end

-- Keybinds
local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.B then
        spawnMultipleBrainrots(TOTAL_TO_SPAWN)
    elseif input.KeyCode == Enum.KeyCode.R then
        clearBrainrots()
    end
end)

print("Local brainrot spawner loaded. Press B to spawn 67 brainrots client-side. Press R to clear.")

